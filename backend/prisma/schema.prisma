// Prisma schema — supports both SQLite (local dev) and PostgreSQL (production on Render)
// Set DATABASE_URL in .env:
//   Local:      DATABASE_URL="file:./dev.db"
//   Production: DATABASE_URL="postgresql://user:pass@host/db?pgbouncer=true"

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   @default("USER") // USER, ADMIN
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          String    @id @default(uuid())
  name        String    // e.g., "Free Fire", "Mobile Legends"
  slug        String    @unique
  image       String    // Logo image URL/path
  category    String    // MOBILE_GAME, PC_GAME, VOUCHER
  isActive    Boolean   @default(true)
  packages    Package[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Package {
  id          String   @id @default(uuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name        String   // e.g., "50 Diamonds", "Weekly Diamond Pass"
  amount      Int      // Numeric representation of package items
  price       Float    // USD price
  isActive    Boolean  @default(true)
  category    String   @default("NORMAL") // BEST_SELLER, NORMAL
  badge       String?  // Optional badge text
  orders      Order[]
  stocks      Stock[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id                 String   @id @default(uuid())
  userId             String?
  user               User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  packageId          String
  package            Package  @relation(fields: [packageId], references: [id])
  playerId           String   // Game Player ID
  playerZoneId       String?  // Optional MLBB Zone ID
  playerNickname     String?  // Fetched nickname from API
  price              Float    // Final price paid
  status             String    @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED, REFUNDED
  paymentMethod      String    // ABA, BAKONG
  paymentStatus      String    @default("PENDING") // PENDING, PAID, EXPIRED
  paymentTxnId       String    @unique             // Transaction ID generated for gateway
  gatewayRef         String?   // Reference ID returned by gateway
  paymentQrCode      String?   // Raw EMVCo KHQR string shown to customer
  paymentMd5         String?   // MD5 of the KHQR string used for Bakong API verification
  paidAt             DateTime? // Timestamp of gateway-confirmed payment
  deliveryStatus     String    @default("WAITING") // WAITING, READY, DELIVERED, FAILED
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  stockDeliveredCode String?   // Code delivered if code voucher
}

model Stock {
  id        String   @id @default(uuid())
  packageId String
  package   Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  code      String   // The digital code/serial to deliver
  isUsed    Boolean  @default(false)
  orderId   String?  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
